{
  "$schema": "https://opencode.ai/config.schema.json",
  "commands": {
    "intake": {
      "path": "commands/intake.md"
    },
    "shape-slice": {
      "path": "commands/shape-slice.md"
    },
    "shape": {
      "path": "commands/shape.md"
    },
    "slice": {
      "path": "commands/slice.md"
    },
    "build": {
      "path": "commands/build.md"
    },
    "verify": {
      "path": "commands/verify.md"
    },
    "resume": {
      "path": "commands/resume.md"
    },
    "fix": {
      "path": "commands/fix.md"
    }
  },
  "agents": {
    "intake-analyst": {
      "path": "agents/intake-analyst.md"
    },
    "solution-shaper": {
      "path": "agents/solution-shaper.md"
    },
    "slice-planner": {
      "path": "agents/slice-planner.md"
    },
    "build-orchestrator": {
      "path": "agents/build-orchestrator.md"
    },
    "tdd-builder": {
      "path": "agents/tdd-builder.md"
    },
    "task-reviewer": {
      "path": "agents/task-reviewer.md"
    },
    "feature-verifier": {
      "path": "agents/feature-verifier.md"
    },
    "review-consolidator": {
      "path": "agents/review-consolidator.md"
    }
  },
  "skills": {
    "behavioral": {
      "note": "Load at agent definition time \u2014 shape how agents reason",
      "lane-classifier": {
        "path": "skills/lane-classifier/SKILL.md"
      },
      "slice-writer": {
        "path": "skills/slice-writer/SKILL.md"
      },
      "tdd-cycle": {
        "path": "skills/tdd-cycle/SKILL.md"
      },
      "task-review-standards": {
        "path": "skills/task-review-standards/SKILL.md"
      },
      "verify-checklist": {
        "path": "skills/verify-checklist/SKILL.md"
      }
    },
    "format": {
      "note": "Load at output-write time \u2014 enforce output structure only",
      "manifest-writer": {
        "path": "skills/manifest-writer/SKILL.md"
      },
      "brief-writer": {
        "path": "skills/brief-writer/SKILL.md"
      },
      "evidence-log-writer": {
        "path": "skills/evidence-log-writer/SKILL.md"
      },
      "review-report-writer": {
        "path": "skills/review-report-writer/SKILL.md"
      }
    }
  },
  "workflow": {
    "manifest_wins": true,
    "generated_files_are_readonly": true,
    "canonical_source": "workflow/<feature>/feature.yaml",
    "note": "Generated markdown files (brief.md, review.md, runs/*.md) are derived views. If they disagree with feature.yaml, the manifest wins. Never treat generated files as orchestration inputs."
  }
}