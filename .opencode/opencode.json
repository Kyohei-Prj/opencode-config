{
  "$schema": "https://opencode.ai/config.json",

  "agent": {

    // ── Stage 1: /spec ────────────────────────────────────────────────────
    "requirements-analyst": {
      "permission": { "skill": { "*": "allow" } }
    },

    // ── Stage 2: /design ─────────────────────────────────────────────────
    "architecture-designer": {
      "permission": { "skill": { "*": "allow" } }
    },

    // ── Stage 3: /plan ────────────────────────────────────────────────────
    "phase-planner": {
      "permission": {
        "skill": { "*": "allow" },
        "task": { "*": "deny", "task-decomposer": "allow" }
      }
    },
    "task-decomposer": {
      "permission": {
        "skill": { "*": "allow" },
        "task": { "*": "deny" }
      }
    },

    // ── Stage 4: /implement ───────────────────────────────────────────────
    "impl-orchestrator": {
      "permission": {
        "skill": { "*": "allow" },
        "task": {
          "*": "deny",
          "tdd-implementer": "allow",
          "test-runner": "allow"
        }
      }
    },
    "tdd-implementer": {
      "permission": {
        "skill": { "*": "allow" },
        "task": { "*": "deny" }
      }
    },
    "test-runner": {
      "permission": {
        "skill": { "*": "allow" },
        "task": { "*": "deny" }
      }
    },

    // ── Stage 5: /review ─────────────────────────────────────────────────
    // review-orchestrator reads code; dispatches code-reviewer + consolidator
    "review-orchestrator": {
      "permission": {
        "skill": { "*": "allow" },
        "task": {
          "*": "deny",
          "code-reviewer": "allow",
          "review-consolidator": "allow"
        }
      }
    },
    // code-reviewer: read-only; no write; reviews one task at a time
    "code-reviewer": {
      "permission": {
        "skill": { "*": "allow" },
        "task": { "*": "deny" }
      }
    },
    // review-consolidator: write-only output; never reads source code
    "review-consolidator": {
      "permission": {
        "skill": { "*": "allow" },
        "task": { "*": "deny" }
      }
    },

    // ── Built-in overrides ────────────────────────────────────────────────
    "plan": {
      "permission": { "skill": { "*": "allow" } }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
	"CONTEXT7_API_KEY": ""
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "CopilotKit MCP": {
      "type": "local",
      "command": [
	"npx",
	"-y",
	"mcp-remote",
	"https://mcp.copilotkit.ai"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "deepwiki": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "serena": {
      "command": [
	"uvx",
	"--from",
	"git+https://github.com/oraios/serena",
	"serena",
	"start-mcp-server",
	"--context",
	"ide-assistant",
	"--project",
	"{cwd}",
	"--enable-web-dashboard",
	"false"
      ],
      "enabled": true,
      "environment": {
	"PYTHONUNBUFFERED": "1"
      },
      "type": "local"
    },
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen3.5-27b": {
          "name": "Qwen3.5-27B",
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
	"gpt-oss-120b": {
	  "name": "gpt-oss-120b",
	  "limit": {
	    "context": 131072,
	    "output": 65536
	  }
	}
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "**/*.min.js",
      "**/*.map",
      "**/*.lock",
      ".venv/**",
      ".opencode/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
